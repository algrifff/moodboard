{
  "name": "@moodboard/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc --noEmit && echo 'build: typecheck only for now'",
    "start": "tsx --env-file=.env src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "tsx --env-file=.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --env-file=.env ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "tsx --env-file=.env ./node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "tsx --env-file=.env ./node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@moodboard/shared": "workspace:*",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.10",
    "nanoid": "^5.1.11",
    "postgres": "^3.4.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
