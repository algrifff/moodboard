PORT=3001
NODE_ENV=development

# Local dev points at docker-compose's Postgres on port 5432.
# Prod (Railway) injects the real DATABASE_URL.
DATABASE_URL=postgres://moodboard:moodboard@localhost:5432/moodboard

# Phase 4b — better-auth
# AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3001

# Phase 5 — Anthropic Claude (required for /api/boards/:id/analyze)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Phase 12 — Notion integration. Set up at
# https://www.notion.so/profile/integrations  →  New integration (Public).
# Capabilities: Read content + Read user information.
#
# IMPORTANT: the redirect URI points at the FRONTEND origin (5173) not the
# API origin (3001). In dev, Vite proxies /api/* to the API; in prod the
# frontend + API are same-origin. This keeps the OAuth state cookie on a
# single host and the better-auth session cookie travels with the popup.
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# NOTION_REDIRECT_URI=http://localhost:5173/api/connections/notion/callback

# Phase 13 — Google Drive integration. Set up via Google Cloud Console:
# enable Drive API + Sheets API + Slides API, OAuth consent screen
# (External), credentials type Web application with the redirect below.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:5173/api/connections/drive/callback

# Server-side AES-256-GCM key for encrypting OAuth tokens at rest. Must be
# exactly 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
# CONNECTION_TOKEN_KEY=

# Origin of the web app that receives postMessage handshakes from the OAuth
# popup callback. Used as the `targetOrigin` arg to window.opener.postMessage —
# must be exact, not '*', so the message can't be received by an attacker
# window holding a reference to our popup.
WEB_ORIGIN=http://localhost:5173
